# Copy to `.env.local` for `pnpm dev`, or to `.env` at the repo root
# for `docker compose up`. Never commit the filled-in version.

# --- World Developer Portal ---------------------------------------------
# Create an app at https://developer.worldcoin.org, register an Incognito
# Action (the identifier goes in NEXT_PUBLIC_ACTION_ID; dashes only —
# underscores are rejected by the portal), and enable the World ID 4.0
# tab so you see an rp_* value.
NEXT_PUBLIC_APP_ID=app_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_ACTION_ID=vohu-vote
NEXT_PUBLIC_RP_ID=rp_xxxxxxxxxxxxxxxx

# RP signing key for IDKit v4 web flow. The private key signs each
# uniqueness request on the server (/api/rp-signature) so World App can
# validate the request context when the user scans the QR.
WORLDCOIN_SIGNER_ADDRESS=0xYourAddress
WORLDCOIN_SIGNER_PRIVATE_KEY=0xYourPrivateKey

# --- Persistence --------------------------------------------------------
# Either (A) Upstash/Vercel KV REST, or (B) a plain Redis URL. vohu's
# store.ts prefers (A) when the REST tokens are present.
#
# (A) Vercel KV / Upstash Redis:
# KV_REST_API_URL=https://xxx.upstash.io
# KV_REST_API_TOKEN=xxxxx
#
# (B) Self-hosted Redis (docker compose fills this automatically):
# REDIS_URL=redis://redis:6379
